{
  "name": "markmap",
  "version": "0.18.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "highlight.js": "^11.9.0",
    "@vscode/markdown-it-katex": "^1.1.0",
    "katex": "0.16.18",
    "prismjs": "^1.29.0",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-mark": "^4.0.0"
  },
  "exports": {
    ".": {
      "import": "./packages/markmap-view/dist/index.mjs",
      "require": "./packages/markmap-view/dist/index.js",
      "types": "./packages/markmap-view/dist/index.d.ts"
    },
    "./view": {
      "import": "./packages/markmap-view/dist/index.mjs",
      "require": "./packages/markmap-view/dist/index.js",
      "types": "./packages/markmap-view/dist/index.d.ts"
    },
    "./lib": {
      "import": "./packages/markmap-lib/dist/index.mjs",
      "require": "./packages/markmap-lib/dist/index.js",
      "types": "./packages/markmap-lib/dist/index.d.ts"
    },
    "./toolbar": {
      "import": "./packages/markmap-toolbar/dist/index.mjs",
      "require": "./packages/markmap-toolbar/dist/index.js",
      "types": "./packages/markmap-toolbar/dist/index.d.ts"
    },
    "./toolbar/style.css": "./packages/markmap-toolbar/dist/style.css",
    "./common": {
      "import": "./packages/markmap-common/dist/index.mjs",
      "require": "./packages/markmap-common/dist/index.js",
      "types": "./packages/markmap-common/dist/index.d.ts"
    },
    "./html-parser": {
      "import": "./packages/markmap-html-parser/dist/index.mjs",
      "require": "./packages/markmap-html-parser/dist/index.js",
      "types": "./packages/markmap-html-parser/dist/index.d.ts"
    },
    "./hljs": {
      "import": "highlight.js",
      "require": "highlight.js"
    },
    "./katex": {
      "import": "katex",
      "require": "katex"
    },
    "./katex/style.css": "katex/dist/katex.min.css",
    "./hljs/style.css": "highlight.js/styles/default.css",
    "./plugins": {
      "import": "./packages/markmap-lib/dist/plugins-loader.mjs",
      "require": "./packages/markmap-lib/dist/plugins-loader.js",
      "types": "./packages/markmap-lib/dist/plugins-loader.d.ts"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@gera2ld/jsx-dom": "^2.2.2",
    "@types/node": "^24.0.1",
    "@unocss/postcss": "^66.2.0",
    "autoprefixer": "^10.4.21",
    "cheerio": "^1.2.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lerna": "^9.0.7",
    "lint-staged": "^16.1.0",
    "npm2url": "^0.2.4",
    "postcss": "^8.5.5",
    "postcss-calc": "^10.1.1",
    "postcss-nested": "^7.0.2",
    "prettier": "^3.5.3",
    "read-package-up": "^11.0.0",
    "typedoc": "^0.28.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "unocss": "^66.2.0",
    "vite": "^6.3.5",
    "vitest": "^3.2.3"
  },
  "scripts": {
    "prepare": "husky || true",
    "build": "pnpm lint && pnpm clean && pnpm build:types && pnpm build:js && pnpm test",
    "lint": "eslint && prettier --check packages/*/src",
    "lint:fix": "eslint --fix && prettier --write packages/*/src",
    "test": "vitest --run",
    "clean": "pnpm -r clean",
    "build:types": "pnpm -r build:types",
    "build:js": "pnpm -r build:js",
    "build:docs": "typedoc --out api --titleLink / --name markmap"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  }
}
